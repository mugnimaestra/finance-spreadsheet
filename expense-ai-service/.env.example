PORT=3000
API_TOKEN=your-secret-token-here

# Model configuration
# Use free model (big-pickle) as primary - delegates to general-gemini subagent
AI_MODEL=opencode/big-pickle

# Agent wrapper: set to "false" to disable wrapper (use model directly)
# Default: true (enabled) - uses big-pickle which delegates to @general-gemini
OPENCODE_AGENT_WRAPPER=true

FINANCE_SKILL_PATH=~/projects/finance-spreadsheet

# Webhook authentication secret - must match WEBHOOK_SECRET on telegram-bot-cloudflare Worker
WEBHOOK_SECRET=your-webhook-secret-here

# Legacy - use AI_MODEL instead
# OPENCODE_MODEL=opencode/big-pickle
